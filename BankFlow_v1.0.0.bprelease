ions,&lt;br&gt;&lt;br&gt;Application &lt;b&gt;&quot; &amp; [Data.ApplicationID] &amp; &quot;&lt;/b&gt; has successfully passed initial KYC validation and has been committed to the SQL database.&lt;br&gt;&lt;br&gt;Regards,&lt;br&gt;BankFlow Digital Worker&quot;" /></inputs><onsuccess>a1e79032-356c-4bb0-a86f-d002965d10a3</onsuccess><processid>64c3f4b3-65cd-4ef1-ad04-0bf627d7f078</processid></stage><stage stageid="88d8acc3-bd1f-42e5-a777-bb03db8d4eea" name="Send Exception Alert  Email" type="SubSheet"><loginhibit onsuccess="true" /><display x="15" y="180" /><inputs><input type="text" name="In_ToAddress" friendlyname="In_ToAddress" expr="&quot;gavinisudhakarreddy@gmail.com&quot;" /><input type="text" name="In_Subject" friendlyname="In_Subject" expr="&quot;KYC Exception Flagged - App ID: &quot; &amp; [Data.ApplicationID]" /><input type="text" name="In_BodyMessage" friendlyname="In_BodyMessage" expr="&quot;Attention Team, a validation error occurred while processing this application.&quot;" /></inputs><onsuccess>a1e79032-356c-4bb0-a86f-d002965d10a3</onsuccess><processid>64c3f4b3-65cd-4ef1-ad04-0bf627d7f078</processid></stage></process></process>
